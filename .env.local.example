# Yerel Postgres (Docker) — bkz. docker-compose.yml
DATABASE_URL=postgres://ozsaye:ozsaye@localhost:5432/ozsaye

# Oturum imza anahtarı: openssl rand -base64 32
SESSION_SECRET=degistir-openssl-rand-base64-32

# Magic-link URL'inin tabanı (dev)
APP_URL=http://localhost:3000

# Üretimde doldurulur (Faz 3 cutover); dev'de boş bırakılırsa e-posta konsola basılır
RESEND_API_KEY=

# Blog görsel yükleme: üretimde Vercel Blob token'ı; dev'de boş kalırsa .uploads/ kullanılır
BLOB_READ_WRITE_TOKEN=

# Üretim staff seed'i: "Ad Soyad:email@alan.com:expert-slug" kayıtları virgülle ayrılır
# Örn: SEED_STAFF=Psk. Dan. Melek Yıldız:melek@ozsaye.com:melek-yildiz,Kl. Psk. Sacide Şahin:sacide@ozsaye.com:sacide-sahin
SEED_STAFF=
