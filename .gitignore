# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# yerel görsel yüklemeleri (dev disk deposu; prod'da Vercel Blob kullanılır)
/.uploads/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright mcp artifacts
.playwright-mcp/

# deploy artefaktları
deploy/
ozsaye-cpanel.zip
ozsaye-psikoloji-static.zip

# Sosyal medya taslak kuyruğu (yerel, üretici çıktısı)
/taslaklar/

# Yerel marka fontları (setup-fonts.sh indirir; OFL, depoya konmaz)
/.fonts/

# Sıfır bağlamlı review raporu (geçici, üretici çıktısı)
review-rapor.md
review-rapor.md.log

# Sürekli review/geliştirme döngüsü çıktıları (review-loop.sh / improve-loop.sh)
/loglar/

# Claude Code oturum artefaktları (subagent worktree'leri vb.)
/.claude/
