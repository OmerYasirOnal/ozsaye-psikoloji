# Özsaye Psikoloji — statik site (Next.js export) için Apache yapılandırması
# GoDaddy paylaşımlı hosting (Apache) üzerinde çalışır.

# Özel 404 sayfası (Next export 404.html üretir)
ErrorDocument 404 /404.html

# Varsayılan belge
DirectoryIndex index.html

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  # Hash'li statik varlıklar (uzun önbellek)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  # HTML kısa önbellek (içerik güncellemeleri hızlı yansısın)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# _next içindeki hash'li dosyalar değişmez olarak işaretlenir
<IfModule mod_headers.c>
  <FilesMatch "\.(woff2|js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
